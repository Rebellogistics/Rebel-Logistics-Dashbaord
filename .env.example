# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
# Get these values from your Supabase project settings at https://app.supabase.com
# Project Settings > API
VITE_SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Google OAuth — used by Phase 5 calendar sync.
# CLIENT_ID is safe to ship to the browser (Vite injects it via the VITE_ prefix).
# CLIENT_SECRET must NEVER be exposed client-side. It is read only by the
# server-side endpoints under /api/auth/google/* — leave the VITE_ prefix off.
# In Vercel: set both as Environment Variables. Locally: use `vercel dev` so
# the API routes can read them.
VITE_GOOGLE_OAUTH_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"

# Google Maps Places autocomplete (Phase 13). Browser-side; restricted to
# HTTP referrers in Google Cloud Console + scoped to Maps JS + Places APIs.
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Server-only Supabase service role key — used by /api/* endpoints to update
# the integrations table on behalf of the authenticated user. NEVER expose
# to the browser.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Twilio (Phase 8 — SMS) — server-only except the public-safe provider flag.
# AUTH_TOKEN must NEVER appear with a VITE_ prefix or in client code.
TWILIO_ACCOUNT_SID="YOUR_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN"
TWILIO_FROM="+61485055666"
# Flip the client off the dev stub once /api/sms/send is deployed.
VITE_SMS_PROVIDER="twilio"

# Owner context for SMS template variables ({{owner.businessName}} and
# {{owner.phone}}). VITE_-prefixed so the client-side renderer can read
# them (auto-fired status SMS + bulk day-prior + SendSmsDialog preview
# all run in the browser). The server-side inbound auto-reply
# (api/sms/inbound.ts) reads the unprefixed REBEL_BUSINESS_NAME and
# REBEL_SUPPORT_PHONE — keep both pairs in sync.
VITE_REBEL_BUSINESS_NAME="Rebel Logistics"
VITE_REBEL_SUPPORT_PHONE="+61 4xx xxx xxx"
REBEL_BUSINESS_NAME="Rebel Logistics"
REBEL_SUPPORT_PHONE="+61 4xx xxx xxx"
